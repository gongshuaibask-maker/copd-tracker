{
  "expo": {
    "name": "慢阻肺自我管理",
    "slug": "copd-tracker",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "copd-tracker",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "backgroundColor": "#2E7D32",
      "resizeMode": "contain",
      "image": "./assets/images/splash-iphone-6.5.png"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.copd.tracker",
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "用于拍摄检查报告照片，识别指标数值",
        "NSPhotoLibraryUsageDescription": "用于从相册选取检查报告照片",
        "ITSAppUsesNonExemptEncryption": false,
        "LSApplicationCategoryType": "public.app-category.medical"
      },
      "config": {
        "usesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.copd.tracker",
      "versionCode": 1,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.RECORD_AUDIO"
      ],
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon-512.png",
        "backgroundColor": "#2E7D32"
      }
    },
    "plugins": [
      "expo-router",
      "expo-sqlite",
      "expo-image-picker",
      "expo-notifications"
    ],
    "extra": {
      "privacyPolicyUrl": "https://copd-selfcare.netlify.app/privacy-policy",
      "supportUrl": "https://copd-selfcare.netlify.app/support",
      "appStoreUrl": "",
      "playStoreUrl": "",
      "webUrl": "https://copd-selfcare.netlify.app",
      "router": {},
      "eas": {
        "projectId": "933f9aed-16dc-4db2-86b2-25581d16d46c"
      }
    }
  }
}
